### 7.3 Key Type Definitions

```typescript
// Frontmatter schema for content/decks/*.md
interface DeckFrontmatter {
  id: string;                    // URL slug: "vue-router-deep-dive"
  title: string;
  description: string;
  tags: Tag[];
  slideCount: number;
  durationMinutes: number;       // Estimated talk duration
  createdAt: string;             // ISO date
  updatedAt: string;             // ISO date
  revealBasePath: string;        // "/reveals/vue-router-deep-dive"
  currentVersion: number;        // Latest version number (e.g., 2)
  versions: DeckVersion[];       // Version history
  events?: string[];             // ["DevNexus 2026", "Connect.Tech 2025"]
  thumbnail?: string;            // Optional preview image path
  tier?: "30min" | "45min" | "60min";
}

interface DeckVersion {
  version: number;               // 1, 2, 3...
  label: string;                 // "Original", "OrlandoCodeCamp26 Update"
  date: string;                  // ISO date of this version
  revealFile: string;            // "v1.html", "v2.html"
  changes?: string;              // Brief changelog: "Added speaker notes, updated branding"
}

// Resolved at runtime — combines frontmatter + computed revealPath
interface Deck extends DeckFrontmatter {
  revealPath: string;            // Computed: `${revealBasePath}/v${currentVersion}.html`
}

type Tag =
  | "vue"
  | "nuxt"
  | "javascript"
  | "typescript"
  | "career"
  | "soft-skills"
  | "fundamentals"
  | "architecture"
  | "accessibility"
  | "community";

interface SearchParams {
  q?: string;
  tags?: string;                 // Comma-separated
  sort?: "newest" | "oldest" | "az" | "za";
}
```

